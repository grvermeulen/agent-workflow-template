# The Pit — environment configuration
# Copy to .env.local and fill in. Every integration is optional: a tool with no
# credentials shows as "offline" in the cockpit instead of breaking the app.

# --- GitHub (the backbone / source of truth) ---
# A token enables the live backlog (issues), in-progress (open PRs) and activity feed.
GITHUB_TOKEN=
# Optional: limit oversight to a single owner (defaults to the token's user).
GITHUB_OWNER=

# --- Vercel ---
VERCEL_TOKEN=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Slack ---
SLACK_BOT_TOKEN=

# --- Atlassian (Jira / Confluence) ---
ATLASSIAN_API_TOKEN=

# --- Cos chat brain (pick one; subscription is preferred over API billing) ---
# Subscription: run `claude setup-token` while signed into your Pro/Max plan and
# paste the token here. The chat then answers via Claude Code on your subscription
# (no API usage). Takes precedence over ANTHROPIC_API_KEY.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Model surfaces Cos oversees ---
# API billing fallback for the chat (used only when CLAUDE_CODE_OAUTH_TOKEN is unset).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
ELEVENLABS_API_KEY=
