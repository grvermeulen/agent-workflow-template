# The Pit — environment configuration
# Copy to .env.local and fill in. Every integration is optional: a tool with no
# credentials shows as "offline" in the cockpit instead of breaking the app.

# --- GitHub (the backbone / source of truth) ---
# A token enables the live backlog (issues), in-progress (open PRs) and activity feed.
# For work delegation (below) it also needs issues:write on COS_WORK_REPO.
GITHUB_TOKEN=
# Optional: limit oversight to a single owner (defaults to the token's user).
GITHUB_OWNER=
# "owner/repo" where Cos opens @claude work issues. When set (with a write token),
# build/deploy/hire chat requests are delegated to Claude Code on your subscription
# via the Claude Code GitHub Action (.github/workflows/claude.yml).
COS_WORK_REPO=

# --- Vercel ---
VERCEL_TOKEN=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Slack ---
SLACK_BOT_TOKEN=

# --- Atlassian (Jira / Confluence) ---
ATLASSIAN_API_TOKEN=

# --- Cos chat brain ---
# Subscription (from `claude setup-token`): the chat answers via Claude Code on
# your subscription — but only on a host that can spawn the CLI subprocess.
# It is SKIPPED on Vercel serverless (which can't), so on Vercel use the API key
# below for chat and the GitHub Action for subscription-powered work.
# (Set COS_FORCE_CLAUDE_CODE=1 to force-enable on a self-managed host.)
CLAUDE_CODE_OAUTH_TOKEN=

# --- Model surfaces Cos oversees ---
# Powers the conversational chat (used when the subscription path can't run, e.g. on Vercel).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
ELEVENLABS_API_KEY=
