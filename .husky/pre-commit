#!/usr/bin/env sh

# 1. Format (Prettier)
STAGED_FILES=$(git diff --name-only --cached --diff-filter=ACMR | grep -E '\.(js|jsx|ts|tsx|json|css|md|mdx|yml|yaml)$' || true)
if [ -n "$STAGED_FILES" ]; then
	npx prettier --write $STAGED_FILES
	git add $STAGED_FILES
fi

# 2. Merge conflict markers (must not reach Turbopack / Next parse)
npm run check:merge-conflicts

# 3. Lint (ESLint)
npm run lint

# 4. Typecheck (TypeScript)
npx tsc --noEmit

# 5. Test (Vitest - Run Once)
npx vitest run
