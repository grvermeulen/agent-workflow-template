# Verplicht: gedeeld geheim (min. 32 tekens). Genereer met: npm run token
COS_BRIDGE_TOKEN=

# Optioneel — defaults tussen haakjes
# COS_BRIDGE_HOST=127.0.0.1        # bind-adres (loopback; tunnel verzorgt de buitenkant)
# COS_BRIDGE_PORT=7070             # poort
# COS_PROJECT_ROOT=                # werkmap voor de shell (~/Projects)
# COS_BRIDGE_MAX_SESSIONS=3        # max gelijktijdige terminals
# COS_BRIDGE_IDLE_MINUTES=60       # sessie sluiten na zoveel minuten stilte
# COS_BRIDGE_MAX_AUTH_FAILURES=5   # foute pogingen voordat een IP geblokkeerd wordt
# COS_BRIDGE_BLOCK_MINUTES=15      # duur van de blokkade
# COS_BRIDGE_ALLOWED_ORIGINS=      # komma-lijst, bijv. https://cockpit.vercel.app
